---
import GitHubMark from "./GitHubMark.astro";

type Props = { githubUrl: string };
const { githubUrl } = Astro.props;
---

<div class="sticky top-4 z-20">
  <div
    class="mx-auto flex max-w-4xl items-center justify-between rounded-full border border-[color:var(--sh-border)] bg-white/70 px-4 py-2 shadow-[var(--sh-shadow-softer)] backdrop-blur-md"
  >
    <a
      href="#horarios"
      class="inline-flex items-center gap-2 rounded-full px-2 py-1 text-sm font-semibold tracking-tight text-[color:var(--sh-ink)] transition hover:bg-white/70"
      aria-label="Ir a horarios"
    >
      <span
        class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-[color:rgba(242,166,120,0.25)]"
      >
        ש
      </span>
      SHABBES
    </a>

    <nav class="hidden items-center gap-1 sm:flex">
      <a
        href="#propuesta"
        class="rounded-full px-3 py-1.5 text-sm text-[color:var(--sh-muted)] transition hover:bg-white/70 hover:text-[color:var(--sh-ink)]"
      >
        Propuesta
      </a>
      <a
        href="#contacto"
        class="rounded-full px-3 py-1.5 text-sm text-[color:var(--sh-muted)] transition hover:bg-white/70 hover:text-[color:var(--sh-ink)]"
      >
        Contacto
      </a>
    </nav>

    <a
      href={githubUrl}
      target="_blank"
      rel="noreferrer"
      class="inline-flex items-center gap-2 rounded-full border border-[color:var(--sh-border)] bg-white/60 px-3 py-1.5 text-sm font-medium text-[color:var(--sh-ink)] transition hover:translate-y-[-1px]"
      aria-label="Ver el repo en GitHub"
    >
      <GitHubMark class="h-4 w-4" />
      <span class="hidden sm:inline">GitHub</span>
    </a>
  </div>
</div>

