---
type Props = {
  country: "AR" | "IL" | "US";
  class?: string;
};

const { country, class: className = "" } = Astro.props;
---

{country === "AR" ? (
  <svg class={className} viewBox="0 0 24 16" role="img" aria-label="Argentina">
    <rect width="24" height="16" rx="3" fill="#74ACDF" />
    <rect y="5.33" width="24" height="5.34" fill="#FFFFFF" />
    <circle cx="12" cy="8" r="1.4" fill="#F6B40E" />
  </svg>
) : country === "US" ? (
  <svg class={className} viewBox="0 0 24 16" role="img" aria-label="United States">
    <rect width="24" height="16" rx="3" fill="#FFFFFF" />
    {Array.from({ length: 7 }).map((_, i) => (
      <rect y={i * 2.28} width="24" height="1.14" fill="#B22234" />
    ))}
    <rect width="10.8" height="8.2" rx="2" fill="#3C3B6E" />
    <circle cx="2.2" cy="2.2" r="0.35" fill="#FFFFFF" />
    <circle cx="4.2" cy="3.2" r="0.35" fill="#FFFFFF" />
    <circle cx="6.2" cy="2.2" r="0.35" fill="#FFFFFF" />
    <circle cx="8.2" cy="3.2" r="0.35" fill="#FFFFFF" />
    <circle cx="3.2" cy="5.2" r="0.35" fill="#FFFFFF" />
    <circle cx="5.2" cy="6.2" r="0.35" fill="#FFFFFF" />
    <circle cx="7.2" cy="5.2" r="0.35" fill="#FFFFFF" />
    <circle cx="9.2" cy="6.2" r="0.35" fill="#FFFFFF" />
  </svg>
) : (
  <svg class={className} viewBox="0 0 24 16" role="img" aria-label="Israel">
    <rect width="24" height="16" rx="3" fill="#FFFFFF" />
    <rect y="1.4" width="24" height="2.2" fill="#0038B8" />
    <rect y="12.4" width="24" height="2.2" fill="#0038B8" />
    <path
      d="M12 4.9 9.2 10h5.6L12 4.9Zm0 6.2L9.2 6h5.6L12 11.1Z"
      fill="none"
      stroke="#0038B8"
      stroke-width="1"
      stroke-linejoin="round"
    />
  </svg>
)}

