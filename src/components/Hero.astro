---
import Candles from "./Candles.astro";
import TimesCard from "./TimesCard.astro";
import Flag from "./Flag.astro";

type Props = {
  title?: string;
  tagline?: string;
  cityOptions: { id: string; label: string }[];
  initialCityId: string;
};

const {
  title = "SHABBES",
  tagline = "horarios reales, en calma",
  cityOptions,
  initialCityId
} = Astro.props;
---

<section id="horarios" class="scroll-mt-24">
  <div class="grid items-center gap-8 md:grid-cols-2">
    <header class="flex flex-col items-center text-center md:items-start md:text-left">
      <Candles class="mb-3 h-24 w-auto md:mb-4" />

      <h1
        class="text-balance text-5xl font-semibold tracking-tight text-[color:var(--sh-ink)] sm:text-6xl"
      >
        {title}
      </h1>
      <p
        class="text-balance mt-3 max-w-prose text-sm text-[color:var(--sh-muted)] sm:text-base"
      >
        {tagline}
      </p>

      <div class="mt-6 flex flex-wrap items-center justify-center gap-2 md:justify-start">
        <button
          type="button"
          data-city-set="buenos_aires"
          class="inline-flex items-center gap-2 rounded-full border border-[color:var(--sh-border)] bg-white/70 px-3 py-2 text-sm font-medium text-[color:var(--sh-ink)] shadow-[var(--sh-shadow-softer)] transition hover:translate-y-[-1px]"
          aria-label="Cambiar a Buenos Aires"
        >
          <Flag country="AR" class="h-4 w-6" />
          AR
        </button>
        <button
          type="button"
          data-city-set="jerusalem"
          class="inline-flex items-center gap-2 rounded-full border border-[color:var(--sh-border)] bg-white/70 px-3 py-2 text-sm font-medium text-[color:var(--sh-ink)] shadow-[var(--sh-shadow-softer)] transition hover:translate-y-[-1px]"
          aria-label="Cambiar a Jerusalem"
        >
          <Flag country="IL" class="h-4 w-6" />
          IL
        </button>
        <button
          type="button"
          data-city-set="new_york"
          class="inline-flex items-center gap-2 rounded-full border border-[color:var(--sh-border)] bg-white/70 px-3 py-2 text-sm font-medium text-[color:var(--sh-ink)] shadow-[var(--sh-shadow-softer)] transition hover:translate-y-[-1px]"
          aria-label="Cambiar a New York"
        >
          <Flag country="US" class="h-4 w-6" />
          US
        </button>
      </div>

      <nav class="mt-6 flex flex-wrap items-center justify-center gap-2 text-sm md:justify-start">
        <a
          href="#propuesta"
          class="rounded-full border border-[color:var(--sh-border)] bg-[color:var(--sh-surface)] px-4 py-2 text-[color:var(--sh-muted)] transition hover:translate-y-[-1px] hover:text-[color:var(--sh-ink)]"
        >
          La propuesta
        </a>
        <a
          href="#contacto"
          class="rounded-full border border-[color:var(--sh-border)] bg-[color:var(--sh-surface)] px-4 py-2 text-[color:var(--sh-muted)] transition hover:translate-y-[-1px] hover:text-[color:var(--sh-ink)]"
        >
          Contacto
        </a>
      </nav>
    </header>

    <div class="md:justify-self-end">
      <TimesCard cityOptions={cityOptions} initialCityId={initialCityId} />
    </div>
  </div>
</section>
