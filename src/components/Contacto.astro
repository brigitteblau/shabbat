---
type Props = {
  id?: string;
  email?: string;
  githubUrl?: string;
};

const {
  id = "contacto",
  email = "hola@shabbes.app",
  githubUrl = "https://github.com/brigitteblau/shabbat"
} = Astro.props;
---

<section id={id} class="scroll-mt-24">
  <div
    class="rounded-[var(--sh-radius-blob)] border border-[color:var(--sh-border)] bg-[color:var(--sh-surface)] shadow-[var(--sh-shadow-soft)] backdrop-blur-sm"
  >
    <div class="p-6 sm:p-8">
      <div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
        <div class="min-w-0">
          <h2 class="text-lg font-semibold tracking-tight text-[color:var(--sh-ink)]">
            Contacto
          </h2>
          <p class="mt-2 text-sm text-[color:var(--sh-muted)] sm:text-base">
            ¿Querés sumar una ciudad, corregir algo o proponer una mejora? Escribime o abrí un
            issue. Me encanta que esto sea comunitario.
          </p>
        </div>

        <div class="hidden shrink-0 md:block">
          <svg
            class="h-20 w-20 text-[color:rgba(242,166,120,0.45)]"
            viewBox="0 0 96 96"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M18 34c0-6 5-11 11-11h38c6 0 11 5 11 11v28c0 6-5 11-11 11H45l-13 9c-1 1-3 0-3-2v-7h-0c-6 0-11-5-11-11V34Z"
              fill="currentColor"
              opacity="0.35"
            />
            <path
              d="M26 40h44M26 50h32"
              stroke="currentColor"
              stroke-width="4"
              stroke-linecap="round"
              opacity="0.75"
            />
            <path
              d="M72 18l2 6 6 2-6 2-2 6-2-6-6-2 6-2 2-6Z"
              fill="currentColor"
              opacity="0.55"
            />
          </svg>
        </div>
      </div>

      <div class="mt-6 grid gap-3 sm:grid-cols-3">
        <div class="rounded-2xl bg-white/60 p-4 transition will-change-transform hover:-translate-y-0.5">
          <p class="text-xs font-medium uppercase tracking-wide text-[color:var(--sh-soft)]">
            Mail
          </p>
          <a
            class="mt-2 inline-flex w-full items-center justify-between gap-2 rounded-xl border border-[color:var(--sh-border)] bg-white/70 px-4 py-2 text-sm font-medium text-[color:var(--sh-ink)] shadow-[var(--sh-shadow-softer)] transition hover:translate-y-[-1px]"
            href={`mailto:${email}?subject=SHABBES%20—%20sumar%20algo`}
          >
            <span class="truncate">{email}</span>
            <span class="text-[color:var(--sh-soft)]">→</span>
          </a>
        </div>

        <div class="rounded-2xl bg-white/60 p-4 transition will-change-transform hover:-translate-y-0.5">
          <p class="text-xs font-medium uppercase tracking-wide text-[color:var(--sh-soft)]">
            GitHub
          </p>
          <a
            class="mt-2 inline-flex w-full items-center justify-between gap-2 rounded-xl border border-[color:var(--sh-border)] bg-white/70 px-4 py-2 text-sm font-medium text-[color:var(--sh-ink)] shadow-[var(--sh-shadow-softer)] transition hover:translate-y-[-1px]"
            href={githubUrl}
            target="_blank"
            rel="noreferrer"
          >
            <span class="truncate">Abrir repo / issues</span>
            <span class="text-[color:var(--sh-soft)]">↗</span>
          </a>
        </div>

        <div class="rounded-2xl bg-white/60 p-4 transition will-change-transform hover:-translate-y-0.5">
          <p class="text-xs font-medium uppercase tracking-wide text-[color:var(--sh-soft)]">
            Sumar ciudad
          </p>
          <ol class="mt-2 list-inside list-decimal text-sm text-[color:var(--sh-muted)]">
            <li>Nombre + TZID</li>
            <li>Lat/long</li>
            <li>
              PR a <code>src/lib/cities.ts</code>
            </li>
          </ol>
        </div>
      </div>
    </div>
  </div>
</section>
