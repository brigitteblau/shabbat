---
type Props = {
  cityOptions: { id: string; label: string; hint?: string }[];
  initialCityId: string;
};

const { cityOptions, initialCityId } = Astro.props;
---

<section
  class="w-full rounded-blob border border-cream-200 bg-white/70 shadow-soft backdrop-blur-sm"
>
  <div class="flex flex-col gap-6 p-6 sm:p-8">
    <header class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div class="min-w-0">
        <h2 class="text-lg font-semibold tracking-tight text-cocoa-600">
          Horarios de Shabbat
        </h2>
        <p id="dateLabel" class="mt-1 text-sm text-cocoa-400">
          —
        </p>
      </div>

      <label class="flex items-center gap-3 self-start sm:self-center">
        <span class="text-sm text-cocoa-500">Ciudad</span>
        <select
          id="citySelect"
          class="rounded-xl border border-cream-200 bg-cream-50 px-3 py-2 text-sm text-cocoa-600 shadow-softer outline-none ring-terracotta-300/40 transition focus:ring-4"
          aria-label="Select city"
        >
          {cityOptions.map((c) => (
            <option value={c.id} selected={c.id === initialCityId}>
              {c.label}
            </option>
          ))}
        </select>
      </label>
    </header>

    <div class="grid gap-3 sm:grid-cols-2">
      <div class="rounded-2xl bg-cream-50/70 p-4">
        <p class="text-xs font-medium uppercase tracking-wide text-cocoa-400">
          Empieza Shabbat
        </p>
        <p
          id="startsLabel"
          class="mt-1 text-2xl font-semibold tracking-tight text-cocoa-600"
        >
          —
        </p>
      </div>

      <div class="rounded-2xl bg-cream-50/70 p-4">
        <p class="text-xs font-medium uppercase tracking-wide text-cocoa-400">
          Termina Shabbat
        </p>
        <p
          id="endsLabel"
          class="mt-1 text-2xl font-semibold tracking-tight text-cocoa-600"
        >
          —
        </p>
      </div>
    </div>

    <div
      class="flex flex-col gap-2 rounded-2xl border border-cream-200 bg-white/70 p-4"
    >
      <p class="text-xs font-medium uppercase tracking-wide text-cocoa-400">
        Ubicación
      </p>
      <p id="locationLabel" class="text-sm font-medium text-cocoa-600">
        —
      </p>
      <p id="statusLabel" class="text-xs text-cocoa-400">
        Cargando…
      </p>
    </div>
  </div>
</section>
