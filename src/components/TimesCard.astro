---
type Props = {
  cityOptions: { id: string; label: string; hint?: string }[];
  initialCityId: string;
};

const { cityOptions, initialCityId } = Astro.props;
---

<section
  class="w-full rounded-[var(--sh-radius-blob)] border border-[color:var(--sh-border)] bg-[color:var(--sh-surface)] shadow-[var(--sh-shadow-soft)] backdrop-blur-sm"
>
  <div class="flex flex-col gap-6 p-6 sm:p-8">
    <header class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div class="min-w-0">
        <h2 class="text-lg font-semibold tracking-tight text-[color:var(--sh-ink)]">
          Horarios de Shabbat
        </h2>
        <p id="dateLabel" class="mt-1 text-sm text-[color:var(--sh-soft)]">
          —
        </p>
      </div>

      <label class="flex items-center gap-3 self-start sm:self-center">
        <span class="text-sm text-[color:var(--sh-muted)]">Ciudad</span>
        <select
          id="citySelect"
          class="rounded-xl border border-[color:var(--sh-border)] bg-white/70 px-3 py-2 text-sm text-[color:var(--sh-ink)] shadow-[var(--sh-shadow-softer)] outline-none ring-[color:rgba(200,122,90,0.35)] transition focus:ring-4"
          aria-label="Select city"
        >
          {cityOptions.map((c) => (
            <option value={c.id} selected={c.id === initialCityId}>
              {c.label}
            </option>
          ))}
        </select>
      </label>
    </header>

    <div class="grid gap-3 sm:grid-cols-2">
      <div class="rounded-2xl bg-white/60 p-4">
        <p class="text-xs font-medium uppercase tracking-wide text-[color:var(--sh-soft)]">
          Empieza Shabbat
        </p>
        <p
          id="startsLabel"
          class="mt-1 text-2xl font-semibold tracking-tight text-[color:var(--sh-ink)]"
        >
          —
        </p>
      </div>

      <div class="rounded-2xl bg-white/60 p-4">
        <p class="text-xs font-medium uppercase tracking-wide text-[color:var(--sh-soft)]">
          Termina Shabbat
        </p>
        <p
          id="endsLabel"
          class="mt-1 text-2xl font-semibold tracking-tight text-[color:var(--sh-ink)]"
        >
          —
        </p>
      </div>
    </div>

    <div
      class="flex flex-col gap-2 rounded-2xl border border-[color:var(--sh-border)] bg-white/70 p-4"
    >
      <p class="text-xs font-medium uppercase tracking-wide text-[color:var(--sh-soft)]">
        Ubicación
      </p>
      <p id="locationLabel" class="text-sm font-medium text-[color:var(--sh-ink)]">
        —
      </p>
      <p id="coordsWrap" class="text-xs text-[color:var(--sh-soft)]">
        <span class="font-medium">Coords</span>:
        <span id="coordsLabel">—</span>
      </p>
      <p id="statusLabel" class="text-xs text-[color:var(--sh-soft)]">
        Cargando…
      </p>
    </div>

    <div id="parashaWrap" class="hidden rounded-2xl bg-white/60 p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-[color:var(--sh-soft)]">
        Parashá
      </p>
      <p id="parashaLabel" class="mt-1 text-sm font-medium text-[color:var(--sh-ink)]">
        —
      </p>
    </div>
  </div>
</section>
