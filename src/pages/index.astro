---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Propuesta from "../components/Propuesta.astro";
import Contacto from "../components/Contacto.astro";
import { CITIES } from "../lib/cities";

const initialCityId = "buenos_aires";
const cityOptions = CITIES.map((c) => ({
  id: c.id,
  label: `${c.label}${c.countryHint ? ` (${c.countryHint})` : ""}`
}));
---

<BaseLayout title="SHABBES" description="Horarios reales de Shabbat, en calma.">
  <main
    class="relative mx-auto flex min-h-dvh max-w-4xl flex-col gap-8 px-5 py-8 sm:px-6 sm:py-12"
  >
    <div
      class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(900px_400px_at_50%_0%,rgba(242,166,120,0.22),transparent_60%),radial-gradient(700px_350px_at_20%_20%,rgba(255,230,200,0.55),transparent_55%)]"
    >
    </div>

    <Navbar githubUrl="https://github.com/brigitteblau/shabbat" />
    <Hero cityOptions={cityOptions} initialCityId={initialCityId} />

    <div data-reveal>
      <Propuesta />
    </div>
    <div data-reveal>
      <Contacto githubUrl="https://github.com/brigitteblau/shabbat" />
    </div>

    <footer class="pt-2 text-center text-xs text-[color:var(--sh-soft)]">
      <span>Datos en tiempo real vía Hebcal (Shabbat API).</span>
      <span class="mx-2 opacity-60">•</span>
      <a
        class="underline decoration-[color:rgba(200,122,90,0.45)] underline-offset-4 transition hover:text-[color:var(--sh-ink)]"
        href="https://github.com/brigitteblau/shabbat"
        target="_blank"
        rel="noreferrer"
      >
        GitHub
      </a>
      <span class="mx-2 opacity-60">•</span>
      <span>hecho con amor</span>
    </footer>
  </main>

  <script>
    import { getCityById } from "../lib/cities";
    import { fetchShabbatTimes } from "../lib/hebcal";

    const citySelect = document.getElementById("citySelect");
    const dateLabel = document.getElementById("dateLabel");
    const startsLabel = document.getElementById("startsLabel");
    const endsLabel = document.getElementById("endsLabel");
    const locationLabel = document.getElementById("locationLabel");
    const statusLabel = document.getElementById("statusLabel");
    const coordsWrap = document.getElementById("coordsWrap");
    const coordsLabel = document.getElementById("coordsLabel");
    const parashaWrap = document.getElementById("parashaWrap");
    const parashaLabel = document.getElementById("parashaLabel");

    function setStatus(text) {
      if (statusLabel) statusLabel.textContent = text;
    }

    function setCoords(city) {
      if (!coordsLabel) return;
      if (!city || typeof city.latitude !== "number" || typeof city.longitude !== "number") {
        coordsLabel.textContent = "—";
        return;
      }
      coordsLabel.textContent = `${city.latitude.toFixed(4)}, ${city.longitude.toFixed(4)}`;
    }

    function setParasha(parashaTitle) {
      const title = typeof parashaTitle === "string" ? parashaTitle.trim() : "";
      if (parashaLabel) parashaLabel.textContent = title || "—";
      if (parashaWrap) parashaWrap.classList.toggle("hidden", !title);
    }

    function setValues({
      locationLabel: loc,
      isoDate,
      startsAtLabel,
      endsAtLabel,
      parashaTitle
    }) {
      if (locationLabel) locationLabel.textContent = loc;
      if (dateLabel) dateLabel.textContent = `Fecha: ${isoDate}`;
      if (startsLabel) startsLabel.textContent = startsAtLabel;
      if (endsLabel) endsLabel.textContent = endsAtLabel;
      setParasha(parashaTitle);
    }

    async function load(cityId) {
      const city = getCityById(cityId);
      setCoords(city);
      setStatus("Cargando…");
      try {
        const times = await fetchShabbatTimes(city);
        const apply = () => setValues(times);
        if (document.startViewTransition) {
          document.startViewTransition(apply);
        } else {
          apply();
        }
        setStatus("Actualizado con datos reales.");
      } catch (err) {
        console.error(err);
        setStatus("No pude cargar la API. Probá de nuevo en unos segundos.");
      }
    }

    const cityButtons = Array.from(document.querySelectorAll("[data-city-set]"));
    cityButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.getAttribute("data-city-set");
        if (!citySelect || !id) return;
        citySelect.value = id;
        citySelect.dispatchEvent(new Event("change", { bubbles: true }));
      });
    });

    const revealEls = Array.from(document.querySelectorAll("[data-reveal]"));
    const revealObs =
      "IntersectionObserver" in window
        ? new IntersectionObserver(
            (entries) => {
              entries.forEach((e) => {
                if (e.isIntersecting) e.target.classList.add("is-visible");
              });
            },
            { threshold: 0.18 }
          )
        : null;
    revealEls.forEach((el) => {
      el.classList.add("reveal");
      if (revealObs) revealObs.observe(el);
      else el.classList.add("is-visible");
    });

    const horarios = document.getElementById("horarios");
    const coordsObs =
      coordsWrap && horarios && "IntersectionObserver" in window
        ? new IntersectionObserver(
            ([entry]) => {
              coordsWrap.classList.toggle("hidden", !entry.isIntersecting);
            },
            { threshold: 0.2 }
          )
        : null;
    if (coordsObs && horarios) coordsObs.observe(horarios);

    if (citySelect) {
      citySelect.addEventListener("change", (e) => {
        const value = e.target && "value" in e.target ? e.target.value : "buenos_aires";
        load(String(value));
      });
      load(String(citySelect.value || "buenos_aires"));
    } else {
      load("buenos_aires");
    }
  </script>
</BaseLayout>
